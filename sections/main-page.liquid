{%- comment -%}
  SmartNest Pet Tech - Main Page Section
{%- endcomment -%}

<!-- Hero Banner -->
<section class="hero-banner" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 80px 0; text-align: center; color: #fff;">
  <div class="container">
    <h1 style="font-size: 48px; margin-bottom: 20px; font-weight: 700;">
      {{ section.settings.hero_title | default: 'Smart Pet Care for Modern Pet Parents' }}
    </h1>
    <p style="font-size: 20px; margin-bottom: 40px; opacity: 0.9;">
      {{ section.settings.hero_subtitle | default: 'Keep Your Pets Safe, Happy & Connected' }}
    </p>
    <div style="display: flex; gap: 20px; justify-content: center;">
      <a href="/collections/all" class="btn" style="background: #fff; color: #667eea; padding: 14px 32px; border-radius: 50px; text-decoration: none; font-weight: 600;">Shop Now</a>
      <a href="/pages/about" class="btn btn-secondary" style="background: transparent; color: #fff; border: 2px solid #fff; padding: 14px 32px; border-radius: 50px; text-decoration: none; font-weight: 600;">Learn More</a>
    </div>
  </div>
</section>

<!-- Featured Products -->
<section class="featured-products" style="padding: 60px 0; background: #f8f9fa;">
  <div class="container">
    <h2 style="text-align: center; margin-bottom: 40px; color: #212529;">Featured Pet Tech Products</h2>
    
    {% if collections.all.products_count > 0 %}
      <div class="product-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
        {% for product in collections.all.products limit: section.settings.product_limit %}
          <div class="product-card" style="background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
            {% if product.featured_media %}
              <img src="{{ product.featured_media | image_url: width: 600 }}" alt="{{ product.title }}" style="width: 100%; height: 280px; object-fit: cover;" loading="lazy">
            {% endif %}
            <div style="padding: 20px;">
              <h3 style="font-size: 18px; margin-bottom: 10px; color: #212529;">{{ product.title }}</h3>
              <p style="font-size: 20px; font-weight: 700; color: #667eea;">{{ product.price | money }}</p>
              <a href="{{ product.url }}" class="btn" style="display: inline-block; margin-top: 15px; background: #667eea; color: #fff; padding: 10px 24px; border-radius: 50px; text-decoration: none;">View Details</a>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <p style="text-align: center; color: #666;">No products available yet.</p>
    {% endif %}
    
    <div style="text-align: center; margin-top: 40px;">
      <a href="/collections/all" class="btn" style="background: #667eea; color: #fff; padding: 14px 32px; border-radius: 50px; text-decoration: none;">View All Products</a>
    </div>
  </div>
</section>

<!-- Features Section -->
<section class="features" style="padding: 80px 0; background: #fff;">
  <div class="container">
    <h2 style="text-align: center; margin-bottom: 60px; color: #212529;">Why Choose SmartNest?</h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 40px;">
      <div style="text-align: center; padding: 30px;">
        <div style="font-size: 48px; margin-bottom: 20px;">🚀</div>
        <h3 style="font-size: 20px; margin-bottom: 10px; color: #212529;">Smart Technology</h3>
        <p style="color: #666; line-height: 1.6;">Latest IoT and AI-powered pet care devices for modern pet parents.</p>
      </div>
      
      <div style="text-align: center; padding: 30px;">
        <div style="font-size: 48px; margin-bottom: 20px;">✓</div>
        <h3 style="font-size: 20px; margin-bottom: 10px; color: #212529;">Quality Assured</h3>
        <p style="color: #666; line-height: 1.6;">All products tested and certified for your pet's safety.</p>
      </div>
      
      <div style="text-align: center; padding: 30px;">
        <div style="font-size: 48px; margin-bottom: 20px;">💬</div>
        <h3 style="font-size: 20px; margin-bottom: 10px; color: #212529;">24/7 Support</h3>
        <p style="color: #666; line-height: 1.6;">Dedicated pet care experts always ready to help.</p>
      </div>
      
      <div style="text-align: center; padding: 30px;">
        <div style="font-size: 48px; margin-bottom: 20px;">📦</div>
        <h3 style="font-size: 20px; margin-bottom: 10px; color: #212529;">Free Shipping</h3>
        <p style="color: #666; line-height: 1.6;">Free shipping on orders over $50 worldwide.</p>
      </div>
    </div>
  </div>
</section>

<!-- Newsletter Section -->
<section class="newsletter-section" style="padding: 60px 0; background: #f5f5f5;">
  <div class="container" style="text-align: center;">
    <h2 style="font-size: 32px; margin-bottom: 15px; color: #212529;">Subscribe & Save 10%</h2>
    <p style="font-size: 16px; margin-bottom: 30px; color: #666;">Join our newsletter and get 10% off your first order!</p>
    
    <form action="/contact#newsletter-form" method="post" style="max-width: 500px; margin: 0 auto; display: flex; gap: 10px;">
      <input type="email" name="contact[email]" placeholder="Enter your email" required style="flex: 1; padding: 14px 20px; border: 1px solid #ccc; border-radius: 50px; background: #fff; color: #333; font-size: 16px;">
      <button type="submit" style="background: #000; color: #fff; padding: 14px 32px; border: none; border-radius: 50px; cursor: pointer; font-weight: 600; font-size: 16px;">Subscribe</button>
    </form>
    
    <p style="font-size: 12px; color: #999; margin-top: 15px;">By subscribing, you agree to our Privacy Policy and consent to receive updates.</p>
  </div>
</section>

{% schema %}
{
  "name": "Main Page",
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero Title",
      "default": "Smart Pet Care for Modern Pet Parents"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Hero Subtitle",
      "default": "Keep Your Pets Safe, Happy & Connected"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to Show",
      "min": 4,
      "max": 12,
      "step": 4,
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Main Page"
    }
  ]
}
{% endschema %}
