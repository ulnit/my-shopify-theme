<header class="header" role="banner">
  <div class="container">
    <div class="header__inner">
      <!-- Logo -->
      <div class="header__logo">
        <a href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 200 | image_tag: alt: shop.name }}
          {%- else -%}
            <span style="font-size: 24px; font-weight: 700; color: #667eea;">🐾 SmartNest</span>
          {%- endif -%}
        </a>
      </div>

      <!-- Navigation -->
      <nav class="header__nav" role="navigation">
        <ul style="display: flex; gap: 30px; list-style: none; margin: 0; padding: 0;">
          <li><a href="/">🏠 Home</a></li>
          <li><a href="/collections/all">🛍️ Shop</a></li>
          <li><a href="/collections/pet-cameras">📹 Cameras</a></li>
          <li><a href="/collections/pet-feeders">🍽️ Feeders</a></li>
          <li><a href="/collections/pet-trackers">📍 Trackers</a></li>
          <li><a href="/blogs/news">📰 Blog</a></li>
          <li><a href="/pages/about">ℹ️ About</a></li>
        </ul>
      </nav>

      <!-- Icons -->
      <div class="header__icons">
        <a href="/search" aria-label="Search" style="color: #212529; font-size: 20px;">🔍</a>
        <a href="/account" aria-label="Account" style="color: #212529; font-size: 20px;">👤</a>
        <a href="{{ routes.cart_url }}" aria-label="Cart" style="color: #212529; font-size: 20px;">
          🛒 <span class="cart-count" style="font-size: 14px;">{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    }
  ]
}
{% endschema %}
