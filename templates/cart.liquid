{%- comment -%}
  SmartNest Pet Tech - Cart Template
  Complete shopping cart with full checkout flow
{%- endcomment -%}

<div class="cart-page" style="max-width: 1400px; margin: 0 auto; padding: 40px 20px;">
  
  <h1 style="font-size: 48px; color: #212529; text-align: center; margin-bottom: 60px;">🛒 Shopping Cart</h1>

  {% if cart.item_count > 0 %}
    
    <!-- Cart Items -->
    <div class="cart-items" style="display: grid; grid-template-columns: 2fr 1fr; gap: 60px; margin-bottom: 60px;">
      
      <!-- Cart Items List -->
      <div class="cart-items-list">
        {% for item in cart.items %}
          <div class="cart-item" style="display: grid; grid-template-columns: 120px 1fr auto; gap: 30px; padding: 30px; background: #fff; border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); margin-bottom: 20px;">
            
            <!-- Product Image -->
            <div class="item-image">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title }}" style="width: 100%; border-radius: 12px;">
              {% else %}
                <div style="width: 100%; height: 120px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 48px;">📦</div>
              {% endif %}
            </div>

            <!-- Product Info -->
            <div class="item-info">
              <h3 style="font-size: 20px; color: #212529; margin-bottom: 10px;">
                <a href="{{ item.url }}" style="color: #212529; text-decoration: none;">{{ item.product.title }}</a>
              </h3>
              
              {% if item.variant.title != 'Default Title' %}
                <p style="color: #666; font-size: 14px; margin-bottom: 10px;">Variant: {{ item.variant.title }}</p>
              {% endif %}
              
              <p style="color: #666; font-size: 14px; margin-bottom: 10px;">SKU: {{ item.variant.sku | default: 'N/A' }}</p>
              
              <!-- Quantity Update Form -->
              <form action="/cart/change" method="post" style="display: flex; align-items: center; gap: 15px; margin-top: 15px;">
                <input type="hidden" name="line" value="{{ forloop.index }}">
                <input type="number" name="quantity" value="{{ item.quantity }}" min="0" max="10" style="width: 80px; padding: 10px; border: 2px solid #ddd; border-radius: 8px; font-size: 16px; text-align: center;">
                <button type="submit" style="padding: 10px 20px; background: #667eea; color: #fff; border: none; border-radius: 8px; font-size: 14px; cursor: pointer;">Update</button>
                <a href="/cart/change?line={{ forloop.index }}&quantity=0" style="color: #dc3545; text-decoration: none; margin-left: 15px; font-size: 14px;">Remove</a>
              </form>
            </div>

            <!-- Item Price -->
            <div class="item-price" style="text-align: right;">
              <p style="font-size: 24px; color: #667eea; font-weight: 700; margin-bottom: 10px;">{{ item.line_price | money }}</p>
              {% if item.original_line_price != item.line_price %}
                <p style="font-size: 16px; color: #999; text-decoration: line-through;">{{ item.original_line_price | money }}</p>
              {% endif %}
              <p style="font-size: 14px; color: #666; margin-top: 10px;">{{ item.quantity }} x {{ item.price | money }}</p>
            </div>

          </div>
        {% endfor %}

        <!-- Continue Shopping -->
        <div style="text-align: center; margin-top: 40px;">
          <a href="/collections/all" style="color: #667eea; text-decoration: none; font-size: 18px; font-weight: 600;">← Continue Shopping</a>
        </div>
      </div>

      <!-- Cart Summary -->
      <div class="cart-summary" style="background: #fff; padding: 40px; border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); height: fit-content; position: sticky; top: 100px;">
        <h2 style="font-size: 28px; color: #212529; margin-bottom: 30px;">Order Summary</h2>

        <!-- Subtotal -->
        <div style="display: flex; justify-content: space-between; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 2px solid #f8f9fa;">
          <span style="color: #666; font-size: 16px;">Subtotal</span>
          <span style="color: #212529; font-size: 20px; font-weight: 700;">{{ cart.total_price | money }}</span>
        </div>

        <!-- Shipping Estimate -->
        <div style="margin-bottom: 20px; padding: 20px; background: #f8f9fa; border-radius: 12px;">
          <p style="color: #666; font-size: 14px; margin-bottom: 10px;">Shipping Estimate</p>
          {% if cart.total_price >= 5000 %}
            <p style="color: #28a745; font-size: 16px; font-weight: 600;">🎉 FREE Shipping!</p>
          {% else %}
            <p style="color: #666; font-size: 14px;">Calculated at checkout</p>
            <p style="color: #667eea; font-size: 13px; margin-top: 5px;">Add {{ 5000 | minus: cart.total_price | money }} more for FREE shipping</p>
          {% endif %}
        </div>

        <!-- Discount Code -->
        <div style="margin-bottom: 30px;">
          <form action="/cart" method="post" style="display: flex; gap: 10px;">
            <input type="text" name="discount" placeholder="Discount code" style="flex: 1; padding: 14px; border: 2px solid #ddd; border-radius: 8px; font-size: 16px;">
            <button type="submit" style="padding: 14px 24px; background: #667eea; color: #fff; border: none; border-radius: 8px; font-size: 16px; cursor: pointer; font-weight: 600;">Apply</button>
          </form>
          {% if cart.cart_level_discount_applications.size > 0 %}
            {% for discount in cart.cart_level_discount_applications %}
              <p style="color: #28a745; font-size: 14px; margin-top: 10px;">✅ Discount: {{ discount.title }} applied</p>
            {% endfor %}
          {% endif %}
        </div>

        <!-- Total -->
        <div style="display: flex; justify-content: space-between; margin-bottom: 30px; padding-top: 20px; border-top: 2px solid #212529;">
          <span style="color: #212529; font-size: 20px; font-weight: 700;">Total</span>
          <span style="color: #667eea; font-size: 28px; font-weight: 700;">{{ cart.total_price | money }}</span>
        </div>

        <!-- Checkout Button -->
        <form action="/checkout" method="post">
          <button type="submit" class="checkout-btn" style="width: 100%; padding: 18px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border: none; border-radius: 50px; font-size: 18px; font-weight: 600; cursor: pointer; transition: transform 0.3s ease; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
            🔒 Proceed to Checkout
          </button>
        </form>

        <!-- Trust Badges -->
        <div style="margin-top: 30px; text-align: center;">
          <div style="display: flex; justify-content: center; gap: 20px; margin-bottom: 20px;">
            <span style="font-size: 32px;">🔒</span>
            <span style="font-size: 32px;">💳</span>
            <span style="font-size: 32px;">🛡️</span>
          </div>
          <p style="color: #666; font-size: 13px; line-height: 1.6;">
            Secure checkout with 256-bit SSL encryption<br>
            We accept all major credit cards and PayPal
          </p>
        </div>

        <!-- Benefits -->
        <div style="margin-top: 30px; padding-top: 30px; border-top: 2px solid #f8f9fa;">
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px;">
            <span style="font-size: 24px;">🚚</span>
            <span style="color: #666; font-size: 14px;">Free shipping on orders over $50</span>
          </div>
          <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 15px;">
            <span style="font-size: 24px;">↩️</span>
            <span style="color: #666; font-size: 14px;">30-day money-back guarantee</span>
          </div>
          <div style="display: flex; align-items: center; gap: 10px;">
            <span style="font-size: 24px;">🛡️</span>
            <span style="color: #666; font-size: 14px;">1-year warranty on all products</span>
          </div>
        </div>

      </div>
    </div>

  {% else %}
    
    <!-- Empty Cart -->
    <div class="empty-cart" style="text-align: center; padding: 100px 20px;">
      <div style="font-size: 120px; margin-bottom: 30px;">🛒</div>
      <h2 style="font-size: 36px; color: #212529; margin-bottom: 20px;">Your cart is empty</h2>
      <p style="color: #666; font-size: 18px; margin-bottom: 40px; max-width: 600px; margin-left: auto; margin-right: auto;">
        Looks like you haven't added any items to your cart yet. Start shopping to see your items here!
      </p>
      <a href="/collections/all" class="btn" style="display: inline-block; padding: 18px 40px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; text-decoration: none; border-radius: 50px; font-size: 18px; font-weight: 600; transition: transform 0.3s ease;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
        🛍️ Start Shopping
      </a>
      
      <!-- Featured Products -->
      <div style="margin-top: 80px;">
        <h3 style="font-size: 28px; color: #212529; margin-bottom: 40px;">Featured Products</h3>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
          {% for i in (1..4) %}
            {% if collections.all.products[i] %}
              <div style="background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.08);">
                <a href="{{ collections.all.products[i].url }}">
                  {% if collections.all.products[i].featured_media %}
                    <img src="{{ collections.all.products[i].featured_media | image_url: width: 400 }}" alt="{{ collections.all.products[i].title }}" style="width: 100%; height: 280px; object-fit: cover;">
                  {% else %}
                    <div style="width: 100%; height: 280px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 72px;">📦</div>
                  {% endif %}
                  <div style="padding: 20px;">
                    <h3 style="font-size: 18px; color: #212529; margin-bottom: 10px; height: 44px; overflow: hidden;">{{ collections.all.products[i].title }}</h3>
                    <p style="font-size: 20px; color: #667eea; font-weight: 700;">{{ collections.all.products[i].price | money }}</p>
                  </div>
                </a>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

  {% endif %}

</div>
