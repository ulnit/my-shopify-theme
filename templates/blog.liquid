{%- comment -%}
  SmartNest Pet Tech - Blog Template
  Display all blog articles
{%- endcomment -%}

<div class="blog-page" style="max-width: 1400px; margin: 0 auto; padding: 40px 20px;">
  
  <!-- Blog Header -->
  <section class="blog-header" style="text-align: center; padding: 80px 0; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; margin-bottom: 60px; border-radius: 16px;">
    <h1 style="font-size: 48px; margin-bottom: 20px; font-weight: 700;">{{ blog.title }}</h1>
    <p style="font-size: 20px; opacity: 0.9; max-width: 800px; margin: 0 auto;">Tips, tricks, and insights for modern pet parents!</p>
  </section>

  <!-- Blog Posts Grid -->
  <section class="blog-posts" style="padding: 60px 0;">
    <div class="container">
      
      {% if blog.articles_count > 0 %}
        {% for article in blog.articles limit: 10 %}
          <article class="blog-post" style="background: #fff; padding: 40px; border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.08); margin-bottom: 40px;">
            <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 40px; align-items: start;">
              <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 40px; border-radius: 12px; text-align: center; color: #fff;">
                <div style="font-size: 72px; margin-bottom: 20px;">📰</div>
                <h2 style="font-size: 24px; margin-bottom: 15px;">{{ article.title }}</h2>
                <p style="opacity: 0.9; font-size: 14px; margin-bottom: 20px;">
                  By {{ article.author }} | {{ article.published_at | date: '%B %d, %Y' }}
                </p>
                <a href="{{ article.url }}" class="btn" style="display: inline-block; background: #fff; color: #667eea; padding: 12px 30px; border-radius: 50px; text-decoration: none; font-weight: 600;">Read More →</a>
              </div>
              <div>
                <div style="color: #666; line-height: 2; font-size: 17px;">
                  {{ article.excerpt_or_content | strip_html | truncatewords: 80 }}
                </div>
                <div style="margin-top: 20px;">
                  {% if article.tags.size > 0 %}
                    <div style="display: flex; gap: 10px; flex-wrap: wrap;">
                      {% for tag in article.tags limit: 5 %}
                        <span style="padding: 6px 16px; background: #f8f9fa; border-radius: 50px; font-size: 14px; color: #667eea;">#{{ tag }}</span>
                      {% endfor %}
                    </div>
                  {% endif %}
                </div>
              </div>
            </div>
          </article>
        {% endfor %}
      {% else %}
        <div style="text-align: center; padding: 60px 0;">
          <h2 style="font-size: 32px; color: #212529; margin-bottom: 20px;">No articles yet</h2>
          <p style="color: #666; font-size: 18px;">Check back soon for pet care tips and insights!</p>
        </div>
      {% endif %}

      <!-- Pagination -->
      {% if paginate.pages > 1 %}
        <div style="text-align: center; margin-top: 40px;">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="btn" style="background: #667eea; color: #fff; padding: 12px 30px; border-radius: 50px; text-decoration: none; font-weight: 600; margin: 0 10px;">Previous</a>
          {% endif %}
          
          <span style="color: #666; font-size: 16px;">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="btn" style="background: #667eea; color: #fff; padding: 12px 30px; border-radius: 50px; text-decoration: none; font-weight: 600; margin: 0 10px;">Next</a>
          {% endif %}
        </div>
      {% endif %}

    </div>
  </section>

  <!-- Newsletter Section -->
  <section class="newsletter" style="padding: 60px 0; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border-radius: 16px; margin-top: 60px;">
    <div class="container" style="text-align: center; padding: 0 20px;">
      <h2 style="font-size: 36px; margin-bottom: 20px;">Subscribe to Our Newsletter</h2>
      <p style="font-size: 18px; opacity: 0.9; margin-bottom: 30px;">Get pet care tips, product updates, and exclusive offers delivered to your inbox.</p>
      <form action="/contact#newsletter-form" method="post" style="max-width: 500px; margin: 0 auto; display: flex; gap: 10px;">
        <input type="email" name="contact[email]" placeholder="Enter your email" required style="flex: 1; padding: 14px 20px; border: none; border-radius: 50px; font-size: 16px;">
        <button type="submit" class="btn" style="background: #fff; color: #667eea; padding: 14px 32px; border: none; border-radius: 50px; cursor: pointer; font-weight: 600;">Subscribe</button>
      </form>
    </div>
  </section>

</div>
