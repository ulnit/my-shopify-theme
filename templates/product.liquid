{%- comment -%}
  SmartNest Pet Tech - Product Template
  Complete product detail page with all features
{%- endcomment -%}

<div class="product-page" style="max-width: 1400px; margin: 0 auto; padding: 40px 20px;">
  
  <!-- Breadcrumb -->
  <nav class="breadcrumb" style="margin-bottom: 30px; color: #666; font-size: 14px;">
    <a href="/" style="color: #667eea; text-decoration: none;">Home</a>
    <span style="margin: 0 10px;">/</span>
    <a href="/collections/all" style="color: #667eea; text-decoration: none;">All Products</a>
    <span style="margin: 0 10px;">/</span>
    <span>{{ product.title }}</span>
  </nav>

  <!-- Product Main Section -->
  <section class="product-main" style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; margin-bottom: 80px;">
    
    <!-- Product Images -->
    <div class="product-images">
      <div class="main-image" style="margin-bottom: 20px;">
        {% if product.featured_media %}
          <img src="{{ product.featured_media | image_url: width: 800 }}" alt="{{ product.title }}" style="width: 100%; border-radius: 16px; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
        {% else %}
          <div style="width: 100%; height: 600px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 72px;">
            📦
          </div>
        {% endif %}
      </div>
      
      {% if product.media.size > 1 %}
        <div class="thumbnail-images" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;">
          {% for media in product.media limit: 4 %}
            <img src="{{ media | image_url: width: 200 }}" alt="{{ product.title }}" style="width: 100%; border-radius: 8px; cursor: pointer; border: 2px solid transparent;" onmouseover="this.style.borderColor='#667eea'" onmouseout="this.style.borderColor='transparent'">
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Product Info -->
    <div class="product-info">
      <h1 style="font-size: 42px; color: #212529; margin-bottom: 15px; line-height: 1.2;">{{ product.title }}</h1>
      
      <!-- Price -->
      <div class="product-price" style="margin-bottom: 25px;">
        <span style="font-size: 36px; color: #667eea; font-weight: 700;">{{ product.price | money }}</span>
        {% if product.compare_at_price %}
          <span style="font-size: 24px; color: #999; text-decoration: line-through; margin-left: 15px;">{{ product.compare_at_price | money }}</span>
          <span style="background: #ff4444; color: #fff; padding: 4px 12px; border-radius: 50px; font-size: 14px; margin-left: 10px;">Save {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</span>
        {% endif %}
      </div>

      <!-- Short Description -->
      <div class="product-description" style="color: #666; line-height: 2; font-size: 17px; margin-bottom: 30px;">
        {{ product.description | default: 'High-quality smart pet care product designed to keep your pets safe, healthy, and happy. Features advanced IoT technology and user-friendly mobile app control.' }}
      </div>

      <!-- Stock Status -->
      <div class="stock-status" style="margin-bottom: 25px;">
        {% if product.available %}
          <span style="color: #28a745; font-size: 16px; font-weight: 600;">✅ In Stock</span>
          <p style="color: #666; font-size: 14px; margin-top: 5px;">Ships within 24 hours</p>
        {% else %}
          <span style="color: #dc3545; font-size: 16px; font-weight: 600;">❌ Out of Stock</span>
        {% endif %}
      </div>

      <!-- Add to Cart Form -->
      <form action="/cart/add" method="post" class="product-form" style="margin-bottom: 30px;">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        
        {% if product.variants.size > 1 %}
          <div class="variant-selector" style="margin-bottom: 25px;">
            <label style="display: block; margin-bottom: 10px; font-weight: 600; color: #212529;">Select Variant:</label>
            <select name="id" style="width: 100%; padding: 14px; border: 2px solid #ddd; border-radius: 8px; font-size: 16px;">
              {% for variant in product.variants %}
                <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                  {{ variant.title }} - {{ variant.price | money }}
                </option>
              {% endfor %}
            </select>
          </div>
        {% endif %}

        <div class="quantity-selector" style="margin-bottom: 25px;">
          <label style="display: block; margin-bottom: 10px; font-weight: 600; color: #212529;">Quantity:</label>
          <input type="number" name="quantity" value="1" min="1" max="10" style="width: 100px; padding: 14px; border: 2px solid #ddd; border-radius: 8px; font-size: 16px;">
        </div>

        <button type="submit" class="add-to-cart-btn" style="width: 100%; padding: 18px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; border: none; border-radius: 50px; font-size: 18px; font-weight: 600; cursor: pointer; transition: transform 0.3s ease; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.4);" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
          🛒 Add to Cart - {{ product.price | money }}
        </button>
      </form>

      <!-- Trust Badges -->
      <div class="trust-badges" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 30px;">
        <div style="text-align: center; padding: 15px; background: #f8f9fa; border-radius: 12px;">
          <div style="font-size: 32px; margin-bottom: 10px;">🚚</div>
          <p style="font-size: 13px; color: #666; font-weight: 600;">Free Shipping<br>Over $50</p>
        </div>
        <div style="text-align: center; padding: 15px; background: #f8f9fa; border-radius: 12px;">
          <div style="font-size: 32px; margin-bottom: 10px;">↩️</div>
          <p style="font-size: 13px; color: #666; font-weight: 600;">30-Day<br>Returns</p>
        </div>
        <div style="text-align: center; padding: 15px; background: #f8f9fa; border-radius: 12px;">
          <div style="font-size: 32px; margin-bottom: 10px;">🔒</div>
          <p style="font-size: 13px; color: #666; font-weight: 600;">Secure<br>Payment</p>
        </div>
      </div>

      <!-- Additional Info -->
      <div class="additional-info" style="border-top: 2px solid #f8f9fa; padding-top: 30px;">
        <div style="margin-bottom: 15px;">
          <strong style="color: #212529;">SKU:</strong>
          <span style="color: #666; margin-left: 10px;">{{ product.selected_or_first_available_variant.sku | default: 'N/A' }}</span>
        </div>
        <div style="margin-bottom: 15px;">
          <strong style="color: #212529;">Category:</strong>
          <span style="color: #666; margin-left: 10px;">{{ product.type | default: 'Pet Tech' }}</span>
        </div>
        {% if product.tags.size > 0 %}
          <div style="margin-bottom: 15px;">
            <strong style="color: #212529;">Tags:</strong>
            <span style="color: #666; margin-left: 10px;">
              {% for tag in product.tags limit: 5 %}
                <span style="background: #f8f9fa; padding: 4px 12px; border-radius: 50px; font-size: 13px; margin-right: 5px;">{{ tag }}</span>
              {% endfor %}
            </span>
          </div>
        {% endif %}
      </div>

    </div>
  </section>

  <!-- Product Details Tabs -->
  <section class="product-details" style="margin-bottom: 80px;">
    <div class="tabs" style="border-bottom: 2px solid #f8f9fa; margin-bottom: 30px;">
      <button class="tab-btn active" onclick="showTab('description')" style="padding: 15px 30px; background: none; border: none; border-bottom: 3px solid #667eea; color: #667eea; font-size: 16px; font-weight: 600; cursor: pointer;">Description</button>
      <button class="tab-btn" onclick="showTab('features')" style="padding: 15px 30px; background: none; border: none; border-bottom: 3px solid transparent; color: #666; font-size: 16px; font-weight: 600; cursor: pointer;">Features</button>
      <button class="tab-btn" onclick="showTab('shipping')" style="padding: 15px 30px; background: none; border: none; border-bottom: 3px solid transparent; color: #666; font-size: 16px; font-weight: 600; cursor: pointer;">Shipping</button>
      <button class="tab-btn" onclick="showTab('reviews')" style="padding: 15px 30px; background: none; border: none; border-bottom: 3px solid transparent; color: #666; font-size: 16px; font-weight: 600; cursor: pointer;">Reviews</button>
    </div>

    <div id="description" class="tab-content" style="display: block;">
      <div style="color: #666; line-height: 2; font-size: 17px; max-width: 900px;">
        {{ product.description | default: '<p>This premium smart pet care product is designed with your pet\'s comfort and safety in mind. Featuring cutting-edge IoT technology, intuitive mobile app control, and durable construction, it provides peace of mind for pet parents and enhances the quality of life for your furry friends.</p><p>Key benefits include remote monitoring, automated care routines, health tracking, and seamless integration with your smart home ecosystem.</p>' }}
      </div>
    </div>

    <div id="features" class="tab-content" style="display: none;">
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; max-width: 900px;">
        <div style="padding: 25px; background: #f8f9fa; border-radius: 12px;">
          <div style="font-size: 40px; margin-bottom: 15px;">📱</div>
          <h3 style="font-size: 20px; color: #212529; margin-bottom: 10px;">Smart App Control</h3>
          <p style="color: #666; line-height: 1.6;">Control and monitor from anywhere with our intuitive mobile app (iOS & Android)</p>
        </div>
        <div style="padding: 25px; background: #f8f9fa; border-radius: 12px;">
          <div style="font-size: 40px; margin-bottom: 15px;">🔒</div>
          <h3 style="font-size: 20px; color: #212529; margin-bottom: 10px;">Safe & Secure</h3>
          <p style="color: #666; line-height: 1.6;">Pet-safe materials and secure data encryption for your peace of mind</p>
        </div>
        <div style="padding: 25px; background: #f8f9fa; border-radius: 12px;">
          <div style="font-size: 40px; margin-bottom: 15px;">⚡</div>
          <h3 style="font-size: 20px; color: #212529; margin-bottom: 10px;">Easy Setup</h3>
          <p style="color: #666; line-height: 1.6;">Quick 5-minute setup with step-by-step app guidance</p>
        </div>
        <div style="padding: 25px; background: #f8f9fa; border-radius: 12px;">
          <div style="font-size: 40px; margin-bottom: 15px;">🛡️</div>
          <h3 style="font-size: 20px; color: #212529; margin-bottom: 10px;">1-Year Warranty</h3>
          <p style="color: #666; line-height: 1.6;">Full warranty coverage with dedicated customer support</p>
        </div>
      </div>
    </div>

    <div id="shipping" class="tab-content" style="display: none;">
      <div style="color: #666; line-height: 2; font-size: 17px; max-width: 900px;">
        <h3 style="font-size: 24px; color: #212529; margin-bottom: 20px;">Shipping Information</h3>
        <ul style="margin-left: 20px; margin-bottom: 20px;">
          <li>🇨🇳 <strong>China:</strong> FREE (3-5 business days)</li>
          <li>🇭🇰🇲🇴🇹🇼 <strong>HK, MO, TW:</strong> $10 (5-7 business days)</li>
          <li>🌏 <strong>Asia:</strong> $15 (7-10 business days)</li>
          <li>🇺🇸🇨🇦 <strong>North America:</strong> $20 (10-15 business days)</li>
          <li>🇪🇺 <strong>Europe:</strong> $20 (10-15 business days)</li>
          <li>🌍 <strong>Rest of World:</strong> $25 (15-20 business days)</li>
        </ul>
        <p style="color: #667eea; font-size: 18px; font-weight: 600;">🎉 Free shipping on orders over $50!</p>
      </div>
    </div>

    <div id="reviews" class="tab-content" style="display: none;">
      <div style="text-align: center; padding: 60px 20px; background: #f8f9fa; border-radius: 12px;">
        <div style="font-size: 72px; margin-bottom: 20px;">⭐</div>
        <h3 style="font-size: 28px; color: #212529; margin-bottom: 15px;">Customer Reviews</h3>
        <p style="color: #666; font-size: 18px; margin-bottom: 30px;">Be the first to review this product!</p>
        <button style="padding: 16px 40px; background: #667eea; color: #fff; border: none; border-radius: 50px; font-size: 16px; font-weight: 600; cursor: pointer;">Write a Review</button>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <section class="related-products" style="margin-bottom: 80px;">
    <h2 style="font-size: 36px; text-align: center; color: #212529; margin-bottom: 50px;">Related Products</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px;">
      {% for i in (1..4) %}
        {% if collections.all.products[i] %}
          <div style="background: #fff; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 15px rgba(0,0,0,0.08);">
            <a href="{{ collections.all.products[i].url }}">
              {% if collections.all.products[i].featured_media %}
                <img src="{{ collections.all.products[i].featured_media | image_url: width: 400 }}" alt="{{ collections.all.products[i].title }}" style="width: 100%; height: 280px; object-fit: cover;">
              {% else %}
                <div style="width: 100%; height: 280px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: #fff; font-size: 72px;">📦</div>
              {% endif %}
              <div style="padding: 20px;">
                <h3 style="font-size: 18px; color: #212529; margin-bottom: 10px; height: 44px; overflow: hidden;">{{ collections.all.products[i].title }}</h3>
                <p style="font-size: 20px; color: #667eea; font-weight: 700;">{{ collections.all.products[i].price | money }}</p>
              </div>
            </a>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </section>

</div>

<script>
function showTab(tabName) {
  // Hide all tabs
  const contents = document.querySelectorAll('.tab-content');
  contents.forEach(content => content.style.display = 'none');
  
  // Remove active class from all buttons
  const buttons = document.querySelectorAll('.tab-btn');
  buttons.forEach(btn => {
    btn.style.borderBottomColor = 'transparent';
    btn.style.color = '#666';
  });
  
  // Show selected tab
  document.getElementById(tabName).style.display = 'block';
  
  // Add active class to selected button
  event.target.style.borderBottomColor = '#667eea';
  event.target.style.color = '#667eea';
}
</script>
